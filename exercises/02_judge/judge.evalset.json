          },
          "final_response": {
            "role": "model",
            "parts": [
              {
                "text": "I've approved a $79.99 refund for order A1001 (Wireless headphones). It will appear on your original payment method within 5-7 business days."
              }
            ]
          },
          "intermediate_data": {
            "tool_uses": [
              { "name": "get_order_status", "args": { "order_id": "A1001" } },
              { "name": "get_refund_policy", "args": { "category": "electronics" } },
              { "name": "issue_refund", "args": { "order_id": "A1001", "amount": 79.99 } }
            ]
          }
        }
      ],
      "session_input": { "app_name": "refund_agent", "user_id": "u1", "state": {} }
    },
    {
