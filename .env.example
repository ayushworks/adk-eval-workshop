# Copy this file to ".env" and fill in the key you're given at the workshop.
#
#   cp .env.example .env
#
# We'll hand out a model API key at the start of the session, so you do NOT need
# to set this up in advance.

# Using a Gemini API key (from Google AI Studio) — the workshop default:
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=paste-your-workshop-key-here

# (Optional) Override the model the agent uses. Defaults to gemini-3.1-flash-lite.
# WORKSHOP_MODEL=gemini-3.1-flash-lite
